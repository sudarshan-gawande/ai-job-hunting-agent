# ============================================================
# JOB HUNTING AGENT v4.0 — Environment Variables
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env     (Linux/Mac)
#   copy .env.example .env   (Windows)
# ============================================================

# ──────────────────────────────────────────────
# REQUIRED: Gmail App Password (for email alerts)
# ──────────────────────────────────────────────
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create app password for "Mail" → Copy the 16-char password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ──────────────────────────────────────────────
# JOB SOURCES (at least one required)
# ──────────────────────────────────────────────

# SerpAPI — Google Jobs search (free: 100 searches/month)
# Sign up at: https://serpapi.com
SERPAPI_KEY=your_serpapi_key

# ──────────────────────────────────────────────
# AI SCORING (both optional — keyword scoring always works)
# ──────────────────────────────────────────────

# Google Gemini — FREE AI scoring (15 requests/min, no credit card)
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API Key" → Copy it
# This is RECOMMENDED — completely free, high quality
GEMINI_API_KEY=your_gemini_key

# Anthropic Claude — Paid AI scoring (~$0.01/job, best quality)
# Only if you have credits at https://console.anthropic.com
# Leave empty if you don't want to pay
ANTHROPIC_API_KEY=your_anthropic_key

# ──────────────────────────────────────────────
# OPTIONAL: Telegram notifications
# ──────────────────────────────────────────────
# Create bot via @BotFather on Telegram → Get token
TELEGRAM_BOT_TOKEN=
